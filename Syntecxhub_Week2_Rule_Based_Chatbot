# Simple inline math evaluator (safe — no eval())
# -------------------------------------------------------
MATH_PATTERN = re.compile(
    r"^\s*(-?\d+(\.\d+)?)\s*([+\-*/])\s*(-?\d+(\.\d+)?)\s*$"
)

