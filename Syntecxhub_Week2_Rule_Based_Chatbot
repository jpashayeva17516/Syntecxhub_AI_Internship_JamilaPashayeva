# main.py

import os
from datetime import datetime
from chatbot import ChatBot

LOG_FILE = "chat_history.txt"

def log_message(role, message):
    """Append a message to the chat history log file."""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(f"[{timestamp}] {role}: {message}\n")

def print_banner():
    print("=" * 50)
    print("       🤖 Rule-Based ChatBot")
    print("       Powered by Python Pattern Matching")
    print("=" * 50)
    print("  Type 'quit' or 'bye' to exit")
    print("  Type 'history' to view chat log")
    print("  Type 'clear' to clear the screen")
    print("=" * 50)

def show_history():
    """Display saved conversation history."""
    if not os.path.exists(LOG_FILE):
        print("\n⚠️  No chat history found yet.")
        return
    print("\n--- 📜 Chat History ---")
    with open(LOG_FILE, "r", encoding="utf-8") as f:
        content = f.read()
        print(content if content.strip() else "  (empty)")
    print("--- End of History ---")

def main():
    bot = ChatBot(name="ChatBot")
    print_banner()

    # Log session start
    log_message("SYSTEM", "=== New session started ===")

    while True:
        try:
            user_input = input("\nYou: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\n\n👋 Goodbye!")
            log_message("SYSTEM", "=== Session ended ===\n")
            break

        if not user_input:
            continue

        # Special commands
        if user_input.lower() == "history":
            show_history()
            continue

        if user_input.lower() == "clear":
            os.system("cls" if os.name == "nt" else "clear")
            print_banner()
            continue

        # Log user input
        log_message("User", user_input)

        # Get and print bot response
        response = bot.get_response(user_input)
        print(f"\n{bot.name}: {response}")

        # Log bot response
        log_message("Bot", response)

        # Exit triggers
        if any(word in user_input.lower()
               for word in ["bye", "goodbye", "quit", "exit"]):
            log_message("SYSTEM", "=== Session ended ===\n")
            break

if __name__ == "__main__":
    main()

