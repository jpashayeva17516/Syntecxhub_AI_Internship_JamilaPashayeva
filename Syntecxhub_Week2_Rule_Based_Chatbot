# chatbot.py

import re
import random
from patterns import INTENTS, MATH_PATTERN

class ChatBot:
    def __init__(self, name="ChatBot"):
        self.name = name

    # -------------------------------------------------------
    # Core response method
    # -------------------------------------------------------
    def get_response(self, user_input):
        text = user_input.strip().lower()

        # 1. Check for inline math expression first
        math_result = self._try_math(text)
        if math_result is not None:
            return f"🔢 Result: {math_result}"

        # 2. Try to match an intent (skip "default" tag)
        for intent in INTENTS:
            if intent["tag"] == "default":
                continue
            for pattern in intent["patterns"]:
                if re.search(pattern, text):
                    return random.choice(intent["responses"])

        # 3. Fallback to default
        default = next(i for i in INTENTS if i["tag"] == "default")
        return random.choice(default["responses"])

    # -------------------------------------------------------
    # Safe math evaluator — no eval()
    # -------------------------------------------------------
    def _try_math(self, text):
        match = MATH_PATTERN.match(text)
        if not match:
            return None
        a  = float(match.group(1))
        op = match.group(3)
        b  = float(match.group(4))

        if op == "+": result = a + b
        elif op == "-": result = a - b
        elif op == "*": result = a * b
        elif op == "/":
            if b == 0:
                return "Error: Division by zero! ❌"
            result = a / b

        # Return int if result is whole number
        return int(result) if result == int(result) else round(result, 4)

