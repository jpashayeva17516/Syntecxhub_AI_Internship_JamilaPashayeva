# model.py

import os
import pickle
import numpy as np
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression
from sklearn.naive_bayes import MultinomialNB
from sklearn.model_selection import train_test_split
from sklearn.metrics import (accuracy_score, f1_score,
                              classification_report, confusion_matrix)
from preprocessor import TextPreprocessor
from data import DATASET

MODEL_FILE = "model.pkl"

class SentimentModel:
    def __init__(self):
        self.preprocessor = TextPreprocessor()
        self.vectorizer    = TfidfVectorizer(ngram_range=(1, 2), max_features=5000)
        self.classifier    = LogisticRegression(max_iter=1000, random_state=42)
        self.is_trained    = False

    # -------------------------------------------------------
    # Train
    # -------------------------------------------------------
    def train(self):
        print("\n⏳ Preparing data...")
        texts  = [self.preprocessor.clean(t) for t, _ in DATASET]
        labels = [label for _, label in DATASET]

        # Split into train / test (80/20)
        X_train, X_test, y_train, y_test = train_test_split(
            texts, labels, test_size=0.2, random_state=42, stratify=labels
        )

        print("⏳ Vectorizing text with TF-IDF...")
        X_train_vec = self.vectorizer.fit_transform(X_train)
        X_test_vec  = self.vectorizer.transform(X_test)

        print("⏳ Training Logistic Regression classifier...")
        self.classifier.fit(X_train_vec, y_train)
        self.is_trained = True

        # Evaluate
        y_pred = self.classifier.predict(X_test_vec)
        self._print_evaluation(y_test, y_pred)

        # Save model to disk
        self.save()

    # -------------------------------------------------------
    # Evaluate
    # -------------------------------------------------------
    def _print_evaluation(self, y_true, y_pred):
        acc = accuracy_score(y_true, y_pred)
        f1  = f1_score(y_true, y_pred, average="weighted")

        print("\n" + "=" * 45)
        print("       📊 Model Evaluation Results")
        print("=" * 45)
        print(f"  Accuracy  : {acc * 100:.2f}%")
        print(f"  F1 Score  : {f1 * 100:.2f}%  (weighted)")
        print("=" * 45)
        print("\n📋 Classification Report:")
        print(classification_report(y_true, y_pred,
              target_names=["negative", "neutral", "positive"]))

        # Confusion Matrix
        cm = confusion_matrix(y_true, y_pred,
                              labels=["negative", "neutral", "positive"])
        print("🔲 Confusion Matrix:")
        print(f"  {'':12} {'Pred NEG':>10} {'Pred NEU':>10} {'Pred POS':>10}")
        print(f"  {'True NEG':12} {cm[0][0]:>10} {cm[0][1]:>10} {cm[0][2]:>10}")
        print(f"  {'True NEU':12} {cm[1][0]:>10} {cm[1][1]:>10} {cm[1][2]:>10}")
        print(f"  {'True POS':12} {cm[2][0]:>10} {cm[2][1]:>10} {cm[2][2]:>10}")

    # -------------------------------------------------------
    # Predict
    # -------------------------------------------------------
    def predict(self, text):
        """Predict sentiment for a single input string."""
        if not self.is_trained:
            raise RuntimeError("Model not trained yet!")

        cleaned = self.preprocessor.clean(text)
        vec     = self.vectorizer.transform([cleaned])
        label   = self.classifier.predict(vec)[0]
        probs   = self.classifier.predict_proba(vec)[0]
        classes = self.classifier.classes_

        # Build confidence scores dict
        confidence = {cls: round(prob * 100, 2)
                      for cls, prob in zip(classes, probs)}
        return label, confidence

    # -------------------------------------------------------
    # Save / Load
    # -------------------------------------------------------
    def save(self):
        with open(MODEL_FILE, "wb") as f:
            pickle.dump({
                "vectorizer": self.vectorizer,
                "classifier": self.classifier
            }, f)
        print(f"\n💾 Model saved to '{MODEL_FILE}'")

    def load(self):
        if not os.path.exists(MODEL_FILE):
            return False
        with open(MODEL_FILE, "rb") as f:
            data = pickle.load(f)
        self.vectorizer = data["vectorizer"]
        self.classifier = data["classifier"]
        self.is_trained = True
        print("✅ Pre-trained model loaded from disk.")
        return True

