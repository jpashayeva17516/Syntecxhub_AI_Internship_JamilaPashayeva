from model import SentimentModel

EMOJI = {
    "positive": "😊 POSITIVE",
    "negative": "😠 NEGATIVE",
    "neutral":  "😐 NEUTRAL"
}

BAR_CHAR = "█"

def confidence_bar(percent, width=20):
    """Draw a simple ASCII progress bar."""
    filled = int(percent / 100 * width)
    return BAR_CHAR * filled + "░" * (width - filled)

def print_banner():
    print("=" * 50)
    print("     🧠 Sentiment Analysis Tool")
    print("     Powered by TF-IDF + Logistic Regression")
    print("=" * 50)
    print("  Type any text to analyse its sentiment.")
    print("  Commands: 'retrain' | 'quit'")
    print("=" * 50)

def print_result(text, label, confidence):
    print("\n" + "─" * 50)
    print(f"  Input     : {text}")
    print(f"  Sentiment : {EMOJI.get(label, label.upper())}")
    print("\n  Confidence Scores:")
    for sentiment in ["positive", "neutral", "negative"]:
        pct = confidence.get(sentiment, 0)
        bar = confidence_bar(pct)
        print(f"    {sentiment.capitalize():<10} [{bar}] {pct:.1f}%")
    print("─" * 50)

def main():
    model = SentimentModel()
    print_banner()

    # Try loading saved model first, else train fresh
    if not model.load():
        print("\n🚀 No saved model found. Training now...")
        model.train()

    while True:
        try:
            user_input = input("\n📝 Enter text: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\n\n👋 Goodbye!")
            break

        if not user_input:
            continue

        if user_input.lower() == "quit":
            print("\n👋 Goodbye!")
            break

        if user_input.lower() == "retrain":
            print("\n🔄 Retraining model from scratch...")
            model.train()
            continue

        # Predict
        try:
            label, confidence = model.predict(user_input)
            print_result(user_input, label, confidence)
        except Exception as e:
            print(f"\n❌ Error: {e}")

if __name__ == "__main__":
    main()

